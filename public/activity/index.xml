    <item>
      <title></title>
      <link>http://localhost:1313/activity/2025/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/activity/2025/</guid>
      <description>&lt;p&gt;&lt;br&gt;&lt;br&gt;&lt;/p&gt;&#xA;&lt;section class=&#34;bar no-mb no-padding ac_2025&#34;&gt;&#xD;&#xA;&lt;div class=&#34;container&#34;&gt;&#xD;&#xA;&lt;div class=&#34;row&#34;&gt;&#xD;&#xA;&lt;div style=&#34;height:70px;&#34;&gt;&lt;/div&gt;&#xD;&#xA;&lt;div class=&#34;heading text-center&#34;&gt;&#xD;&#xA;&lt;h1&gt;2025年度活動&lt;/h1&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;p&gt;&lt;img src=&#34;http://localhost:1313/img/2025/active_2025.webp&#34;&#xD;&#xA;class=&#34;main-image&#34;&#xD;&#xA;onclick=&#34;openModal(&#39;/img/2025/active_2025.webp&#39;)&#34;&gt;&lt;/p&gt;&#xA;&lt;div style=&#34;height:20px;&#34;&gt;&lt;/div&gt;&#xD;&#xA;&lt;!-- 21th NSE --&gt;&#xD;&#xA;&lt;div class=&#34;toggle-wrap&#34;&gt;&#xD;&#xA;&lt;button onclick=&#34;toggleAfter(this)&#34; class=&#34;toggle-btn&#34;&gt;&#xD;&#xA;&lt;div class=&#34;toggle-main&#34;&gt;第21回能代宇宙イベント&lt;/div&gt;&#xD;&#xA;&lt;div class=&#34;toggle-sub&#34;&gt;&#xD;&#xA;&lt;span class=&#34;toggle-icon&#34;&gt;▼&lt;/span&gt;&#xD;&#xA;21thNSE&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/button&gt;&#xD;&#xA;&lt;div style=&#34;height:30px;&#34;&gt;&lt;/div&gt;&#xD;&#xA;&lt;div class=&#34;after-content&#34;&gt;&#xD;&#xA;&lt;div class=&#34;row activity-block&#34;&gt;&#xD;&#xA;&lt;div style=&#34;height:70px;&#34;&gt;&lt;/div&gt;&#xD;&#xA;&lt;div class=&#34;col-md-6&#34;&gt;&#xD;&#xA;&lt;div class=&#34;section-title&#34;&gt;&#xD;&#xA;&lt;h2&gt;21thNSE&lt;/h2&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;b&gt;&#xD;&#xA;高度取得を目的とし，かつシンプルな目標として，&#xD;&#xA;&#34;高度3776 mに到達するハイブリッドロケットの製作とその実証&#34;をミッションに決定しました．&#xD;&#xA;新規エンジンシリーズのMIGRAIRAシリーズから，新型エンジンのMIGRAIRA.illisを開発，その燃焼に成功しました．&#xD;&#xA;&lt;span class=&#34;line-2025&#34;&gt;団体として始めての&lt;/span&gt;，&#xD;&#xA;4700ccの酸化剤に対応したM型エンジンとなりました．&#xD;&#xA;高度3776mに達したことは確認できませんでしたが，打上げに成功しました．&#xD;&#xA;&lt;/b&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;div class=&#34;col-md-6&#34;&gt;&#xD;&#xA;&lt;div class=&#34;slideshow-container&#34;&gt;&#xD;&#xA;&lt;img class=&#34;slide active&#34; src=&#34;http://localhost:1313/img/2025/2025_1.webp&#34;&gt;&#xD;&#xA;&lt;img class=&#34;slide&#34; src=&#34;http://localhost:1313/img/2025/2025_2.webp&#34;&gt;&#xD;&#xA;&lt;img class=&#34;slide&#34; src=&#34;http://localhost:1313/img/2025/2025_3.webp&#34;&gt;&#xD;&#xA;&lt;img class=&#34;slide&#34; src=&#34;http://localhost:1313/img/2025/2025_4.webp&#34;&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;div class=&#34;row activity-block&#34;&gt;&#xD;&#xA;&lt;div class=&#34;col-md-1&#34;&gt;&lt;/div&gt;&#xD;&#xA;&lt;div class=&#34;col-md-6&#34;&gt;&#xD;&#xA;&lt;div class=&#34;section-title&#34;&gt;&#xD;&#xA;&lt;h2&gt;機体概要&lt;/h2&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;ul class=&#34;spec-list&#34;&gt;&#xD;&#xA;&lt;li class=&#34;spec-main&#34;&gt;&lt;span class=&#34;spec-title&#34;&gt;機体名：&lt;/span&gt;富嶽&lt;/li&gt;&#xD;&#xA;&lt;li class=&#34;spec-main&#34;&gt;&lt;span class=&#34;spec-title&#34;&gt;全長：&lt;/span&gt;&lt;span class=&#34;spec-value&#34;&gt;2201 mm&lt;/span&gt;&lt;/li&gt;&#xD;&#xA;&lt;li class=&#34;spec-main&#34;&gt;&lt;span class=&#34;spec-title&#34;&gt;乾燥質量：&lt;/span&gt;&lt;span class=&#34;spec-value&#34;&gt;13.34 kg&lt;/span&gt;&lt;/li&gt;&#xD;&#xA;&lt;li class=&#34;spec-main&#34;&gt;&#xD;&#xA;&lt;span class=&#34;spec-title&#34;&gt;使用エンジン：&lt;/span&gt;&#xD;&#xA;&lt;div style=&#34;margin-left:40px;&#34;&gt;&#xD;&#xA;&lt;span class=&#34;spec-value&#34;&gt;MIGRAIRA.illis（自作M型，ステム式）&lt;/span&gt;&lt;br&gt;&#xD;&#xA;&lt;span class=&#34;spec-value&#34;&gt;タンク容量：4700cc&lt;/span&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/li&gt;&#xD;&#xA;&lt;li class=&#34;spec-main&#34;&gt;&#xD;&#xA;&lt;span class=&#34;spec-title&#34;&gt;開放機構：&lt;/span&gt;&#xD;&#xA;&lt;span class=&#34;spec-value&#34;&gt;縦開放，放出ペイロードなし&lt;/span&gt;&#xD;&#xA;&lt;/li&gt;&#xD;&#xA;&lt;li class=&#34;spec-main&#34;&gt;&#xD;&#xA;&lt;span class=&#34;spec-title&#34;&gt;搭載計器：&lt;/span&gt;&#xD;&#xA;&lt;div style=&#34;margin-left:40px;&#34;&gt;&#xD;&#xA;&lt;span class=&#34;spec-value&#34;&gt;加速度計・ジャイロセンサ・磁力センサ・気圧センサ・差圧センサ・GNSSモジュール・無線モジュール・カメラ&lt;/span&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/li&gt;&#xD;&#xA;&lt;/ul&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;div class=&#34;col-md-5 image-center&#34;&gt;&#xD;&#xA;&lt;img src=&#34;http://localhost:1313/img/2025/2025_16.webp&#34;&#xD;&#xA;class=&#34;content-image&#34;&#xD;&#xA;onclick=&#34;openModal(&#39;/img/2025/2025_16.webp&#39;)&#34;&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;!-- 27th ISE --&gt;&#xD;&#xA;&lt;div class=&#34;toggle-wrap&#34;&gt;&#xD;&#xA;&lt;button onclick=&#34;toggleAfter(this)&#34; class=&#34;toggle-btn&#34;&gt;&#xD;&#xA;&lt;div class=&#34;toggle-main&#34;&gt;第27回伊豆大島共同打上実験&lt;/div&gt;&#xD;&#xA;&lt;div class=&#34;toggle-sub&#34;&gt;&#xD;&#xA;&lt;span class=&#34;toggle-icon&#34;&gt;▼&lt;/span&gt;&#xD;&#xA;27thISE&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/button&gt;&#xD;&#xA;&lt;div style=&#34;height:30px;&#34;&gt;&lt;/div&gt;&#xD;&#xA;&lt;div class=&#34;after-content&#34;&gt;&#xD;&#xA;&lt;div class=&#34;row activity-block&#34;&gt;&#xD;&#xA;&lt;div style=&#34;height:70px;&#34;&gt;&lt;/div&gt;&#xD;&#xA;&lt;div class=&#34;col-md-6&#34;&gt;&#xD;&#xA;&lt;div class=&#34;section-title&#34;&gt;&#xD;&#xA;&lt;h2&gt;27thISE&lt;/h2&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;b&gt;&#xD;&#xA;本プロジェクトでは，新入生がロケットの製作手法を学び，技術の継承を行うことを主目的とした．&#xD;&#xA;また，カメラを搭載したCOREロケットちゃんの放出にあたり，シミュレータの精度向上および減速&#xD;&#xA;装置放出機構の改良に取り組むことをミッションとした．伊豆大島裏砂漠での打上げにおいて，現地審査で構造的トラブルが&#xD;&#xA;発生した．加えて，実験当日の風況も考慮した結果，安全性の観点から打上げを断念した．&#xD;&#xA;&lt;/b&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;div class=&#34;col-md-6&#34;&gt;&#xD;&#xA;&lt;div class=&#34;slideshow-container&#34;&gt;&#xD;&#xA;&lt;img class=&#34;slide active&#34; src=&#34;http://localhost:1313/img/2025/2025_6.webp&#34;&gt;&#xD;&#xA;&lt;img class=&#34;slide&#34; src=&#34;http://localhost:1313/img/2025/2025_7.webp&#34;&gt;&#xD;&#xA;&lt;img class=&#34;slide&#34; src=&#34;http://localhost:1313/img/2025/2025_8.webp&#34;&gt;&#xD;&#xA;&lt;img class=&#34;slide&#34; src=&#34;http://localhost:1313/img/2025/2025_9.webp&#34;&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;div class=&#34;row activity-block&#34;&gt;&#xD;&#xA;&lt;div class=&#34;col-md-1&#34;&gt;&lt;/div&gt;&#xD;&#xA;&lt;div class=&#34;col-md-4&#34;&gt;&#xD;&#xA;&lt;div class=&#34;section-title&#34;&gt;&#xD;&#xA;&lt;h2&gt;機体概要&lt;/h2&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;ul class=&#34;spec-list&#34;&gt;&#xD;&#xA;&lt;li class=&#34;spec-main&#34;&gt;&lt;span class=&#34;spec-title&#34;&gt;機体名：&lt;/span&gt;C-REX&lt;/li&gt;&#xD;&#xA;&lt;li class=&#34;spec-main&#34;&gt;&lt;span class=&#34;spec-title&#34;&gt;全長：&lt;/span&gt;&lt;span class=&#34;spec-value&#34;&gt;1685 mm&lt;/span&gt;&lt;/li&gt;&#xD;&#xA;&lt;li class=&#34;spec-main&#34;&gt;&lt;span class=&#34;spec-title&#34;&gt;乾燥質量：&lt;/span&gt;&lt;span class=&#34;spec-value&#34;&gt;6.65 kg&lt;/span&gt;&lt;/li&gt;&#xD;&#xA;&lt;li class=&#34;spec-main&#34;&gt;&#xD;&#xA;&lt;span class=&#34;spec-title&#34;&gt;使用エンジン：&lt;/span&gt;&#xD;&#xA;&lt;div style=&#34;margin-left:40px;&#34;&gt;&#xD;&#xA;&lt;span class=&#34;spec-value&#34;&gt;HyperTEK J250&lt;/span&gt;&lt;br&gt;&#xD;&#xA;&lt;span class=&#34;spec-value&#34;&gt;タンク容量：440cc&lt;/span&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/li&gt;&#xD;&#xA;&lt;li class=&#34;spec-main&#34;&gt;&#xD;&#xA;&lt;span class=&#34;spec-title&#34;&gt;開放機構：&lt;/span&gt;&#xD;&#xA;&lt;span class=&#34;spec-value&#34;&gt;フェアリング，ペイロード放出&lt;/span&gt;&#xD;&#xA;&lt;/li&gt;&#xD;&#xA;&lt;li class=&#34;spec-main&#34;&gt;&#xD;&#xA;&lt;span class=&#34;spec-title&#34;&gt;搭載計器：&lt;/span&gt;&#xD;&#xA;&lt;div style=&#34;margin-left:40px;&#34;&gt;&#xD;&#xA;&lt;span class=&#34;spec-value&#34;&gt;加速度計・ジャイロセンサ・磁力センサ・気圧センサ・差圧センサ・GNSSモジュール・無線モジュール・カメラ&lt;/span&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/li&gt;&#xD;&#xA;&lt;/ul&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;div class=&#34;col-md-7 image-center&#34;&gt;&#xD;&#xA;&lt;img src=&#34;http://localhost:1313/img/2025/2025_10.webp&#34;&#xD;&#xA;class=&#34;content-image&#34;&#xD;&#xA;onclick=&#34;openModal(&#39;/img/2025/2025_10.webp&#39;)&#34;&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;!-- 27th ISE --&gt;&#xD;&#xA;&lt;div class=&#34;toggle-wrap&#34;&gt;&#xD;&#xA;&lt;button onclick=&#34;toggleAfter(this)&#34; class=&#34;toggle-btn&#34;&gt;&#xD;&#xA;&lt;div class=&#34;toggle-main&#34;&gt;第28回伊豆大島共同打上実験&lt;/div&gt;&#xD;&#xA;&lt;div class=&#34;toggle-sub&#34;&gt;&#xD;&#xA;&lt;span class=&#34;toggle-icon&#34;&gt;▼&lt;/span&gt;&#xD;&#xA;28thISE&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/button&gt;&#xD;&#xA;&lt;div style=&#34;height:30px;&#34;&gt;&lt;/div&gt;&#xD;&#xA;&lt;div class=&#34;after-content&#34;&gt;&#xD;&#xA;&lt;div class=&#34;row activity-block&#34;&gt;&#xD;&#xA;&lt;div style=&#34;height:70px;&#34;&gt;&lt;/div&gt;&#xD;&#xA;&lt;div class=&#34;col-md-6&#34;&gt;&#xD;&#xA;&lt;div class=&#34;section-title&#34;&gt;&#xD;&#xA;&lt;h2&gt;28thISE&lt;/h2&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;b&gt;&#xD;&#xA;スパイクノズルを搭載した，エアロスパイクエンジン（ASE）によるロケットの飛翔実証をミッションに設定して．&#xD;&#xA;プロジェクトを発足した．エンジンには，新型エンジンの&#34;LIATRIS.llara&#34;を採用した．また，本エンジンの&#xD;&#xA;ノズル形状に適合させるため，過去のプロジェクトで実績のあるバルブシステムを基盤としつつ，酸素逆ステムを備えた構成へと&#xD;&#xA;，バルブシステムの改良を施した．&#xD;&#xA;伊豆大島トウシキ園地にて行われた打上実験で，打上げに成功し，&lt;span class=&#34;line-2025&#34;&gt;全国の学生団体として初めて&lt;/span&gt;，ASE搭載機体の飛翔に成功した．&#xD;&#xA;&lt;/b&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;div class=&#34;col-md-6&#34;&gt;&#xD;&#xA;&lt;div class=&#34;slideshow-container&#34;&gt;&#xD;&#xA;&lt;img class=&#34;slide active&#34; src=&#34;http://localhost:1313/img/2025/2025_11.webp&#34;&gt;&#xD;&#xA;&lt;img class=&#34;slide&#34; src=&#34;http://localhost:1313/img/2025/2025_12.webp&#34;&gt;&#xD;&#xA;&lt;img class=&#34;slide&#34; src=&#34;http://localhost:1313/img/2025/2025_13.webp&#34;&gt;&#xD;&#xA;&lt;img class=&#34;slide&#34; src=&#34;http://localhost:1313/img/2025/2025_14.webp&#34;&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;div class=&#34;row activity-block&#34;&gt;&#xD;&#xA;&lt;div class=&#34;col-md-1&#34;&gt;&lt;/div&gt;&#xD;&#xA;&lt;div class=&#34;col-md-6&#34;&gt;&#xD;&#xA;&lt;div class=&#34;section-title&#34;&gt;&#xD;&#xA;&lt;h2&gt;機体概要&lt;/h2&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;ul class=&#34;spec-list&#34;&gt;&#xD;&#xA;&lt;li class=&#34;spec-main&#34;&gt;&lt;span class=&#34;spec-title&#34;&gt;機体名：&lt;/span&gt;AS-01 はるかぜ&lt;/li&gt;&#xD;&#xA;&lt;li class=&#34;spec-main&#34;&gt;&lt;span class=&#34;spec-title&#34;&gt;全長：&lt;/span&gt;&lt;span class=&#34;spec-value&#34;&gt;1854 mm&lt;/span&gt;&lt;/li&gt;&#xD;&#xA;&lt;li class=&#34;spec-main&#34;&gt;&lt;span class=&#34;spec-title&#34;&gt;乾燥質量：&lt;/span&gt;&lt;span class=&#34;spec-value&#34;&gt;10.53 kg&lt;/span&gt;&lt;/li&gt;&#xD;&#xA;&lt;li class=&#34;spec-main&#34;&gt;&#xD;&#xA;&lt;span class=&#34;spec-title&#34;&gt;使用エンジン：&lt;/span&gt;&#xD;&#xA;&lt;div style=&#34;margin-left:40px;&#34;&gt;&#xD;&#xA;&lt;span class=&#34;spec-value&#34;&gt;LIATRIS.llara（自作L型，バルブ式）&lt;/span&gt;&lt;br&gt;&#xD;&#xA;&lt;span class=&#34;spec-value&#34;&gt;タンク容量：2000cc&lt;/span&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/li&gt;&#xD;&#xA;&lt;li class=&#34;spec-main&#34;&gt;&#xD;&#xA;&lt;span class=&#34;spec-title&#34;&gt;開放機構：&lt;/span&gt;&#xD;&#xA;&lt;span class=&#34;spec-value&#34;&gt;縦開放，放出ペイロードなし&lt;/span&gt;&#xD;&#xA;&lt;/li&gt;&#xD;&#xA;&lt;li class=&#34;spec-main&#34;&gt;&#xD;&#xA;&lt;span class=&#34;spec-title&#34;&gt;搭載計器：&lt;/span&gt;&#xD;&#xA;&lt;div style=&#34;margin-left:40px;&#34;&gt;&#xD;&#xA;&lt;span class=&#34;spec-value&#34;&gt;加速度計・ジャイロセンサ・磁力センサ・気圧センサ・差圧センサ・GNSSモジュール・無線モジュール・カメラ&lt;/span&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/li&gt;&#xD;&#xA;&lt;/ul&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;div class=&#34;col-md-5 image-center&#34;&gt;&#xD;&#xA;&lt;img src=&#34;http://localhost:1313/img/2025/2025_15.webp&#34;&#xD;&#xA;class=&#34;content-image&#34;&#xD;&#xA;onclick=&#34;openModal(&#39;/img/2025/2025_15.webp&#39;)&#34;&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/section&gt;&#xD;&#xA;&lt;div id=&#34;imgModal&#34; class=&#34;modal&#34; onclick=&#34;closeModal()&#34;&gt;&#xD;&#xA;&lt;span class=&#34;close&#34;&gt;&amp;times;&lt;/span&gt;&#xD;&#xA;&lt;img id=&#34;modalImage&#34; class=&#34;modal-content&#34;&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;style&gt;&#xD;&#xA;.ac_2025 {&#xD;&#xA;    background: #fff;&#xD;&#xA;    padding: 40px 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.spec-main {&#xD;&#xA;    margin-top: 20px;&#xD;&#xA;    font-weight: bold;&#xD;&#xA;    line-height: 1.8;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.spec-title {&#xD;&#xA;    font-size: 20px;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.spec-value {&#xD;&#xA;    font-size: 15px;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.ac_2025 b {&#xD;&#xA;    display: block;&#xD;&#xA;    width: 85%;&#xD;&#xA;    font-size: 6pt;&#xD;&#xA;    line-height: 2.4;&#xD;&#xA;    margin: 0 auto;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.line-2025 {&#xD;&#xA;    color: #b23131;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.section-title h2 {&#xD;&#xA;    font-size: 32px;&#xD;&#xA;    margin-bottom: 20px;&#xD;&#xA;    display: inline-block;&#xD;&#xA;    padding-bottom: 8px;&#xD;&#xA;    border-bottom: 3px solid #da4d4d;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.main-image {&#xD;&#xA;    width: 100%;&#xD;&#xA;    cursor: pointer;&#xD;&#xA;    display: block;&#xD;&#xA;    margin: 0 auto 40px;&#xD;&#xA;    border-radius: 10px;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.activity-block {&#xD;&#xA;    margin-bottom: 60px;&#xD;&#xA;    align-items: center;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.image-center {&#xD;&#xA;    text-align: center;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.content-image {&#xD;&#xA;    width: 70%;&#xD;&#xA;    cursor: pointer;&#xD;&#xA;    border-radius: 10px;&#xD;&#xA;    transition: 0.3s;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.content-image:hover {&#xD;&#xA;    transform: scale(1.03);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.toggle-wrap {&#xD;&#xA;    margin: 20px 0;&#xD;&#xA;    width: 100%;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.toggle-btn {&#xD;&#xA;    width: 100%;&#xD;&#xA;    padding: 16px 18px;&#xD;&#xA;    background: #fff;&#xD;&#xA;    color: #da4d4d;&#xD;&#xA;    border: 2px solid #da4d4d;&#xD;&#xA;    border-radius: 14px;&#xD;&#xA;    cursor: pointer;&#xD;&#xA;    display: flex;&#xD;&#xA;    flex-direction: column;&#xD;&#xA;    align-items: center;&#xD;&#xA;    gap: 4px;&#xD;&#xA;    box-shadow: 0 6px 18px rgba(0,0,0,0.08);&#xD;&#xA;    transition: 0.25s ease;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.toggle-btn:hover {&#xD;&#xA;    transform: translateY(-2px);&#xD;&#xA;    background: #fff5f5;&#xD;&#xA;    box-shadow: 0 10px 22px rgba(218,77,77,0.18);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.toggle-btn:active {&#xD;&#xA;    transform: scale(0.98);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.toggle-main {&#xD;&#xA;    font-size: 17px;&#xD;&#xA;    font-weight: 700;&#xD;&#xA;    color: #b23131;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.toggle-sub {&#xD;&#xA;    font-size: 12px;&#xD;&#xA;    display: flex;&#xD;&#xA;    align-items: center;&#xD;&#xA;    gap: 6px;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.toggle-icon {&#xD;&#xA;    font-weight: 900;&#xD;&#xA;    color: #da4d4d;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.after-content {&#xD;&#xA;    display: none;&#xD;&#xA;    opacity: 0;&#xD;&#xA;    max-height: 0;&#xD;&#xA;    overflow: hidden;&#xD;&#xA;    transition: 0.4s;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.after-content.show {&#xD;&#xA;    opacity: 1;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.slideshow-container {&#xD;&#xA;    width: 100%;&#xD;&#xA;    aspect-ratio: 4/3;&#xD;&#xA;    position: relative;&#xD;&#xA;    overflow: hidden;&#xD;&#xA;    border-radius: 10px;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.slide {&#xD;&#xA;    position: absolute;&#xD;&#xA;    width: 100%;&#xD;&#xA;    height: 100%;&#xD;&#xA;    object-fit: cover;&#xD;&#xA;    opacity: 0;&#xD;&#xA;    transition: 1s;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.slide.active {&#xD;&#xA;    opacity: 1;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.modal {&#xD;&#xA;    display: none;&#xD;&#xA;    position: fixed;&#xD;&#xA;    z-index: 9999;&#xD;&#xA;    left: 0;&#xD;&#xA;    top: 0;&#xD;&#xA;    width: 100%;&#xD;&#xA;    height: 100%;&#xD;&#xA;    background: rgba(0,0,0,0.92);&#xD;&#xA;    justify-content: center;&#xD;&#xA;    align-items: flex-start;&#xD;&#xA;    overflow: auto;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.modal-content {&#xD;&#xA;    margin-top: 100px;&#xD;&#xA;    max-width: 92%;&#xD;&#xA;    max-height: calc(100vh - 120px);&#xD;&#xA;    border-radius: 10px;&#xD;&#xA;}&#xD;&#xA;@media (max-width: 600px) {&#xD;&#xA;    .spec-title {&#xD;&#xA;        font-size: 15px;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    .spec-value {&#xD;&#xA;        font-size: 12px;&#xD;&#xA;    }&#xD;&#xA;    .ac_2025 b {&#xD;&#xA;        width:100%;&#xD;&#xA;        font-size: 10pt;&#xD;&#xA;        line-height: 2;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&lt;/style&gt;&#xD;&#xA;&lt;script&gt;&#xD;&#xA;let slideIndex = 0;&#xD;&#xA;const slides = document.getElementsByClassName(&#34;slide&#34;);&#xD;&#xA;&#xD;&#xA;function showSlides() {&#xD;&#xA;    for (let i = 0; i &lt; slides.length; i++) {&#xD;&#xA;        slides[i].classList.remove(&#34;active&#34;);&#xD;&#xA;    }&#xD;&#xA;    slideIndex++;&#xD;&#xA;    if (slideIndex &gt; slides.length) slideIndex = 1;&#xD;&#xA;    slides[slideIndex - 1].classList.add(&#34;active&#34;);&#xD;&#xA;    setTimeout(showSlides, 5000);&#xD;&#xA;}&#xD;&#xA;showSlides();&#xD;&#xA;&#xD;&#xA;function openModal(src) {&#xD;&#xA;    document.getElementById(&#34;imgModal&#34;).style.display = &#34;flex&#34;;&#xD;&#xA;    document.getElementById(&#34;modalImage&#34;).src = src;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;function closeModal() {&#xD;&#xA;    document.getElementById(&#34;imgModal&#34;).style.display = &#34;none&#34;;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;function toggleAfter(btn) {&#xD;&#xA;    const wrap = btn.closest(&#34;.toggle-wrap&#34;);&#xD;&#xA;    const area = wrap.querySelector(&#34;.after-content&#34;);&#xD;&#xA;    const icon = btn.querySelector(&#34;.toggle-icon&#34;);&#xD;&#xA;&#xD;&#xA;    const isOpen = area.classList.contains(&#34;show&#34;);&#xD;&#xA;&#xD;&#xA;    if (isOpen) {&#xD;&#xA;        area.style.maxHeight = &#34;0px&#34;;&#xD;&#xA;        area.style.opacity = &#34;0&#34;;&#xD;&#xA;        area.classList.remove(&#34;show&#34;);&#xD;&#xA;&#xD;&#xA;        setTimeout(() =&gt; {&#xD;&#xA;            area.style.display = &#34;none&#34;;&#xD;&#xA;        }, 300);&#xD;&#xA;&#xD;&#xA;        icon.textContent = &#34;▼&#34;;&#xD;&#xA;    } else {&#xD;&#xA;        area.style.display = &#34;block&#34;;&#xD;&#xA;&#xD;&#xA;        setTimeout(() =&gt; {&#xD;&#xA;            area.style.maxHeight = &#34;2000px&#34;;&#xD;&#xA;            area.style.opacity = &#34;1&#34;;&#xD;&#xA;            area.classList.add(&#34;show&#34;);&#xD;&#xA;        }, 10);&#xD;&#xA;&#xD;&#xA;        icon.textContent = &#34;▲&#34;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;function startSlides(container) {&#xD;&#xA;    const slides = container.getElementsByClassName(&#34;slide&#34;);&#xD;&#xA;    let index = 0;&#xD;&#xA;&#xD;&#xA;    function run() {&#xD;&#xA;        for (let i = 0; i &lt; slides.length; i++) {&#xD;&#xA;            slides[i].classList.remove(&#34;active&#34;);&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;        index++;&#xD;&#xA;        if (index &gt; slides.length) index = 1;&#xD;&#xA;&#xD;&#xA;        slides[index - 1].classList.add(&#34;active&#34;);&#xD;&#xA;        setTimeout(run, 5000);&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    run();&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// 全スライドに対して個別起動&#xD;&#xA;document.querySelectorAll(&#34;.slideshow-container&#34;).forEach(startSlides);&#xD;&#xA;&lt;/script&gt;</description>
